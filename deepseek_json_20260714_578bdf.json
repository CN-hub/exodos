{
    "name": "ravetech/exodo",
    "description": "Êxodo - Sistema de Controle Fiscal para Escritório Digital",
    "type": "project",
    "keywords": ["fiscal", "contabilidade", "escritorio", "digital", "sped", "sefaz"],
    "homepage": "https://www.ravetech.com.br",
    "license": "proprietary",
    "authors": [
        {
            "name": "Cleilton Nascimento",
            "email": "cleilton@ravetech.com.br",
            "role": "CEO & Founder"
        }
    ],
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^6.8",
        "firebase/php-jwt": "^6.9",
        "setasign/fpdi": "^2.3",
        "tecnickcom/tcpdf": "^6.6",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "RavenTech\\Exodo\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\""
        ],
        "test": "phpunit",
        "update": "php update/update.php"
    }
}